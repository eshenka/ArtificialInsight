{
  "openapi": "3.1.0",
  "info": {
    "title": "Gateway Service",
    "description": "HTTP Gateway for Controller gRPC Service",
    "version": "0.1.0"
  },
  "paths": {
    "/answer": {
      "post": {
        "summary": "Answer Prompt",
        "description": "Receives a user prompt and forwards it to the controller service.\nRequires 'Authorization' header with the user token.",
        "operationId": "answer_prompt_answer_post",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromptRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnswerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pipeline": {
      "post": {
        "summary": "Create Pipeline",
        "description": "Creates a new RAG pipeline by forwarding the request to the controller service.\nAccepts application/x-www-form-urlencoded data.\nThe 'rules' field must be a JSON string representing the ScrapeRules structure.",
        "operationId": "create_pipeline_pipeline_post",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/Body_create_pipeline_pipeline_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PipelineResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnswerResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          }
        },
        "type": "object",
        "required": [
          "answer"
        ],
        "title": "AnswerResponse"
      },
      "Body_create_pipeline_pipeline_post": {
        "properties": {
          "user_name": {
            "type": "string",
            "title": "User Name"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "language": {
            "type": "string",
            "title": "Language"
          },
          "entry_docs_url": {
            "type": "string",
            "title": "Entry Docs Url"
          },
          "rules_json": {
            "type": "string",
            "title": "Rules Json"
          }
        },
        "type": "object",
        "required": [
          "user_name",
          "description",
          "language",
          "entry_docs_url",
          "rules_json"
        ],
        "title": "Body_create_pipeline_pipeline_post"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PipelineResponse": {
        "properties": {
          "token": {
            "type": "string",
            "title": "Token"
          }
        },
        "type": "object",
        "required": [
          "token"
        ],
        "title": "PipelineResponse"
      },
      "PromptRequest": {
        "properties": {
          "prompt": {
            "type": "string",
            "title": "Prompt"
          }
        },
        "type": "object",
        "required": [
          "prompt"
        ],
        "title": "PromptRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}